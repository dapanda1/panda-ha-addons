{
  "name": "Plex WoL Listener",
  "version": "5.0",
  "slug": "plex_wol_listener",
  "description": "Proxies Plex traffic, wakes server via WoL, auto-sleeps on idle, Plex token validation, GeoIP blocking, flood detection, HA sensors, dashboard toggles, and notifications",
  "arch": ["aarch64", "amd64"],
  "startup": "services",
  "boot": "auto",
  "host_network": true,
  "init": false,
  "homeassistant_api": true,
  "options": {
    "plex_server_ip": "0.0.0.0",
    "target_mac": "00:00:00:00:00:00",
    "broadcast": "0.0.0.0",
    "listen_port": 32400,
    "plex_server_port": 32400,
    "rate_limit_seconds": 30,
    "wake_timeout_seconds": 120,
    "flood_threshold": 20,
    "flood_window_seconds": 60,
    "enable_user_tracking": false,
    "plex_admin_token": "",
    "enable_geoip": true,
    "allowed_countries": "US",
    "enable_ip_allowlist": false,
    "ip_allowlist": "",
    "enable_ip_blocklist": false,
    "ip_blocklist": "",
    "enable_nowake_list": false,
    "nowake_list": "",
    "enable_sleep_trigger": false,
    "sleep_idle_minutes": 0,
    "max_awake_minutes": 0,
    "server_ssh_user": "",
    "server_ssh_port": 22,
    "enable_health_check": true,
    "health_check_port": 32401,
    "enable_ha_sensors": true,
    "enable_dashboard_toggles": true,
    "enable_file_logging": true,
    "log_retention_days": 14,
    "enable_quiet_mode": false,
    "user_friendly_names": "",
    "enable_smart_wol": false,
    "smart_wol_burst_count": 3,
    "smart_wol_burst_window": 15
  },
  "schema": {
    "plex_server_ip": "str",
    "target_mac": "str",
    "broadcast": "str",
    "listen_port": "int",
    "plex_server_port": "int",
    "rate_limit_seconds": "int",
    "wake_timeout_seconds": "int",
    "flood_threshold": "int",
    "flood_window_seconds": "int",
    "enable_user_tracking": "bool",
    "plex_admin_token": "str",
    "enable_geoip": "bool",
    "allowed_countries": "str",
    "enable_ip_allowlist": "bool",
    "ip_allowlist": "str",
    "enable_ip_blocklist": "bool",
    "ip_blocklist": "str",
    "enable_nowake_list": "bool",
    "nowake_list": "str",
    "enable_sleep_trigger": "bool",
    "sleep_idle_minutes": "int",
    "max_awake_minutes": "int",
    "server_ssh_user": "str",
    "server_ssh_port": "int",
    "enable_health_check": "bool",
    "health_check_port": "int",
    "enable_ha_sensors": "bool",
    "enable_dashboard_toggles": "bool",
    "enable_file_logging": "bool",
    "log_retention_days": "int",
    "enable_quiet_mode": "bool",
    "user_friendly_names": "str",
    "enable_smart_wol": "bool",
    "smart_wol_burst_count": "int",
    "smart_wol_burst_window": "int"
  }
}
